# Example Terraform variables file
# Copy this to terraform.tfvars and fill in your values

# ============================================================================
# REQUIRED VARIABLES - You must set these values
# ============================================================================

# The Linode API token (personal access token) should have read/write access
# for LKE, Linodes, and NodeBalancers.
linode_token = "your-linode-api-token-here"

# ============================================================================
# OPTIONAL VARIABLES - All variables below have defaults and are optional
# ============================================================================

# Optional: Cluster configuration (defaults shown)
#
# cluster_label = "photo-styling"
# k8s_version   = "1.32"
# region        = "us-sea"

# Optional: Node pool instance types (defaults shown)
#
# VLM GPU node: RTX 4000 Ada x1 Medium (20GB VRAM, 32GB RAM)
# vlm_node_type = "g2-gpu-rtx4000a1-m"
#
# Image Generator GPU node: RTX 4000 Ada x2 Medium (40GB VRAM, 65GB RAM)
# imagegen_node_type = "g2-gpu-rtx4000a2-m"
#
# App CPU node: 2 CPU, 4GB RAM (Linode 4GB shared)
# app_node_type = "g6-standard-2"

# Optional: Tags (defaults shown)
#
# tags = ["photo-styling"]
